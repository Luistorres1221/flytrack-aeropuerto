# Copia a .env para desarrollo local. En Vercel define estas variables en el panel (Settings → Environment Variables).

# URL base del API Spring Boot, SIN barra final. El código añade /api/...
# Producción: https://tu-servicio.onrender.com
# Local: http://localhost:8081
VITE_API_URL=http://localhost:8081

# Auth Supabase (obligatorio si usas login/registro del proyecto)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

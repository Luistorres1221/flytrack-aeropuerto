# Copia a .env para desarrollo local. En Vercel define estas variables en el panel (Settings → Environment Variables).

# URL base del API Spring Boot. El código quita barras finales si las pones. Añade /api/... automáticamente.
# Producción: https://tu-servicio.onrender.com
# Local: http://localhost:8081
VITE_API_URL=http://localhost:8081

# Auth Supabase (opcional: solo vuelos/equipaje/admin con API solo necesitas VITE_API_URL)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
